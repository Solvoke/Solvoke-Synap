# ============================================================
# Synap Web - Environment Variables
# ============================================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#
# .env 已在 .gitignore 中，不会提交到仓库。
# ============================================================

# ------------------------------------------------------------
# Database (Required)
# ------------------------------------------------------------
# PostgreSQL 连接字符串
# 格式：postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://username:password@127.0.0.1:5432/synap"
